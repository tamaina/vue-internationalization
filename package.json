{
  "name": "vue-internationalization",
  "version": "0.0.0",
  "type": "module",
  "private": true,
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js"
    },
    "./runtime": {
      "types": "./dist/runtime.d.ts",
      "import": "./dist/runtime.js"
    },
    "./virtual": {
      "types": "./dist/virtual.d.ts",
      "default": "./dist/virtual.d.ts"
    },
    "./volar": {
      "types": "./dist/volar.d.ts",
      "require": "./dist/volar.cjs",
      "import": "./dist/volar.js"
    }
  },
  "files": [
    "dist"
  ],
  "scripts": {
    "build": "tsc -p tsconfig.build.json && cp src/virtual.d.ts dist/virtual.d.ts && tsc -p tsconfig.volar-cjs.json && node scripts/build-volar-cjs.mjs",
    "lint": "eslint .",
    "test": "vitest run",
    "typecheck": "tsc -p tsconfig.json --noEmit"
  },
  "peerDependencies": {
    "vite": "^7.0.0",
    "vue": "^3.5.0"
  },
  "dependencies": {
    "@vue/compiler-sfc": "^3.5.24",
    "typescript": "^5.9.3",
    "yaml": "^2.8.2"
  },
  "devDependencies": {
    "@eslint/compat": "^2.1.0",
    "@eslint/eslintrc": "^3.3.5",
    "@eslint/js": "^9.39.4",
    "@misskey-dev/eslint-plugin": "^2.2.1",
    "@stylistic/eslint-plugin": "^5.10.0",
    "@types/node": "^24.10.1",
    "@typescript-eslint/eslint-plugin": "^8.59.4",
    "@typescript-eslint/parser": "^8.59.4",
    "@vitejs/plugin-vue": "^6.0.2",
    "@vue/language-core": "^3.3.1",
    "eslint": "^9.39.4",
    "eslint-plugin-import": "^2.32.0",
    "globals": "^17.6.0",
    "vite": "^7.2.4",
    "vitest": "^4.0.13",
    "vue": "^3.5.24"
  }
}

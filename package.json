{
  "name": "vite-vue-internationalization",
  "version": "0.3.0",
  "description": "A Vite plugin for typed Vue SFC translations with SFC custom blocks and inline locale chunks",
  "type": "module",
  "packageManager": "pnpm@11.3.0",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "https://github.com/aqz/vue-internationalization"
  },
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js"
    },
    "./runtime": {
      "types": "./dist/runtime.d.ts",
      "import": "./dist/runtime.js"
    },
    "./virtual": {
      "types": "./dist/virtual.d.ts",
      "default": "./dist/virtual.d.ts"
    },
    "./volar": {
      "types": "./dist/volar.d.ts",
      "require": "./dist/volar.cjs",
      "import": "./dist/volar.js"
    }
  },
  "files": [
    "dist",
    "docs/api.md",
    "docs/en/**/*.md",
    "llms.txt"
  ],
  "publishConfig": {
    "access": "public"
  },
  "scripts": {
    "clean": "node -e \"const fs=require('node:fs'); fs.rmSync('dist',{recursive:true,force:true}); fs.rmSync('.volar-cjs-build',{recursive:true,force:true});\"",
    "build": "pnpm clean && tsc -p tsconfig.build.json && cp src/virtual.d.ts dist/virtual.d.ts && tsc -p tsconfig.volar-cjs.json && node scripts/build-volar-cjs.mjs",
    "docs:api": "typedoc && node scripts/build-api-docs.mjs",
    "docs:build": "pnpm docs:prepare && pnpm docs:api && vitepress build docs",
    "docs:dev": "pnpm docs:prepare && pnpm docs:api && vitepress dev docs",
    "docs:prepare": "node scripts/prepare-vitepress.mjs",
    "docs:preview": "pnpm docs:prepare && vitepress preview docs",
    "example:icu": "pnpm build && pnpm --filter ./examples/icu dev",
    "example:vue": "pnpm build && pnpm --filter ./examples/vue dev",
    "lint": "eslint .",
    "prepublishOnly": "pnpm test && pnpm typecheck && pnpm lint && pnpm build",
    "test": "vitest run",
    "typecheck": "tsc -p tsconfig.json --noEmit"
  },
  "peerDependencies": {
    "vite": "^7.0.0",
    "vue": "^3.5.0"
  },
  "dependencies": {
    "@formatjs/icu-messageformat-parser": "^3.5.10",
    "@vue/compiler-sfc": "^3.5.24",
    "acorn": "^8.16.0",
    "estree-walker": "^3.0.3",
    "intl-messageformat": "^11.2.7",
    "magic-string": "^0.30.21",
    "typescript": "^5.9.3",
    "yaml": "^2.8.2"
  },
  "devDependencies": {
    "@eslint/compat": "^2.1.0",
    "@eslint/eslintrc": "^3.3.5",
    "@eslint/js": "^9.39.4",
    "@misskey-dev/eslint-plugin": "^2.2.1",
    "@stylistic/eslint-plugin": "^5.10.0",
    "@types/node": "^24.10.1",
    "@typescript-eslint/eslint-plugin": "^8.59.4",
    "@typescript-eslint/parser": "^8.59.4",
    "@vitejs/plugin-vue": "^6.0.2",
    "@vue/language-core": "^3.3.1",
    "eslint": "^9.39.4",
    "eslint-plugin-import": "^2.32.0",
    "globals": "^17.6.0",
    "typedoc": "^0.28.19",
    "typedoc-plugin-markdown": "^4.11.0",
    "vite": "^7.2.4",
    "vitepress": "^1.6.4",
    "vitest": "^4.0.13",
    "vue": "^3.5.24"
  }
}

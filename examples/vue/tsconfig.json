{
  "vueCompilerOptions": {
    "plugins": [
      {
        "name": "vite-vue-internationalization/volar",
        "primaryLocale": "ja-JP",
        "buildStrategy": "inline-chunks",
        "messageSyntax": "vue",
        "global": {
          "ja-JP": "./src/locales/ja-JP.yaml",
          "en-US": "./src/locales/en-US.yaml"
        }
      }
    ]
  }
}

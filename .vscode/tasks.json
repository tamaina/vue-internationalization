{
	"version": "2.0.0",
	"tasks": [
		{
			"label": "docs:dev",
			"type": "shell",
			"command": "pnpm docs:prepare && pnpm docs:api && pnpm exec vitepress dev docs --port 4000 --host 127.0.0.1",
			"isBackground": true,
			"problemMatcher": {
				"owner": "vitepress",
				"pattern": {
					"regexp": "^$"
				},
				"background": {
					"activeOnStart": true,
					"beginsPattern": "vitepress v",
					"endsPattern": "Local:"
				}
			},
			"presentation": {
				"panel": "dedicated",
				"reveal": "silent"
			},
			"runOptions": {
				"runOn": "folderOpen"
			}
		}
	]
}
